{
  "name": "dev-social",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,game -c blue,magenta \"npm:dev:next\" \"npm:dev:game\"",
    "dev:next": "next dev",
    "dev:game": "tsx watch server/index.ts",
    "build": "next build",
    "start": "concurrently -n next,game -c blue,magenta \"next start\" \"npm:start:game\"",
    "start:game": "tsx server/index.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "dotenv": "^17.4.2",
    "geist": "^1.7.2",
    "nanoid": "^5.1.14",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
