# Copy this file to `.env` (same directory as docker-compose.yml), then fill in
# the secret below:
#
#   cp .env.docker.example .env
#
# docker compose automatically reads `.env` for ${VAR} substitution.
#
# This is the Supabase service_role key. It BYPASSES RLS, so it must NEVER be
# committed or exposed to the browser — only the game server reads it at runtime.
# Get it from: Supabase Dashboard -> Project Settings -> API keys -> service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Note: the public values (project URL, publishable anon key, game-server URL)
# live as build args in docker-compose.yml because NEXT_PUBLIC_* must be baked
# in at build time. If you change the public origin, rebuild the image.

# Browser Google Maps key for the Real GeoGuessr game. It's a NEXT_PUBLIC_*
# build arg (inlined at build time), so set it here and docker-compose will pass
# it through, or hardcode it in docker-compose.yml. Restrict it by HTTP referrer
# in the Google Cloud Console. Without it, GeoGuessr shows a setup hint.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-browser-maps-key
