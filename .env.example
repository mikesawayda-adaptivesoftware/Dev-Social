# Copy to .env.local and fill in. Get values from the Supabase dashboard.

# ---- Public client config (safe to expose in the browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# ---- Server-only config (DO NOT expose to the browser) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: override the realtime server port / client origin
# GAME_SERVER_PORT=3001
# NEXT_PUBLIC_GAME_SERVER_URL=http://localhost:3001
