# Copy to .env.local and fill in. Get values from the Supabase dashboard.

# ---- Public client config (safe to expose in the browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Google Maps JavaScript API key for the "Real GeoGuessr" game (Street View +
# the guess map). This is exposed to the browser, so restrict it in the Google
# Cloud Console to HTTP referrers (your domains + localhost) and to the
# "Maps JavaScript API". See the README for the full setup.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-browser-maps-key

# Optional: a cloud-configured Map ID (Google Cloud Console > Map Management).
# Required for the AdvancedMarkerElement pins used on the guess/reveal maps.
# Leave unset to use Google's DEMO_MAP_ID, which works for local dev.
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your-map-id

# ---- Server-only config (DO NOT expose to the browser) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: only used by scripts/resolvePanos.mjs when curating the GeoGuessr
# location pool (resolves lat/lng -> Street View panorama IDs). Not needed at
# runtime. Can be the same key as above but without referrer restrictions.
# GOOGLE_MAPS_API_KEY=your-server-maps-key

# Optional: override the realtime server port / client origin
# GAME_SERVER_PORT=3001
# NEXT_PUBLIC_GAME_SERVER_URL=http://localhost:3001
